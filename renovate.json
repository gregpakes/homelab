{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],

  "argocd": {
    "managerFilePatterns": ["/argocd/apps/.+\\.yaml$/"]
  },
  "kubernetes": {
    "managerFilePatterns": ["/argocd/infrastructure/.+\\.yaml$/"]
  },
  "helm-values": {
    "managerFilePatterns": ["/argocd/infrastructure/.+/values\\.yaml$/"]
  }
}
