{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],

  "argocd": {
    "managerFilePatterns": ["/argocd/apps/.+\\.yaml$/"]
  },
  "kubernetes": {
    "managerFilePatterns": ["/argocd/infrastructure/.+\\.yaml$/"]
  },
  "helm-values": {
    "managerFilePatterns": ["/argocd/infrastructure/.+/values\\.yaml$/"]
  },
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/linuxserver/nzbget"],
      "versioning": "regex:^version-v(?<major>\\d+)\\.(?<minor>\\d+)$"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/lukegus/termix"],
      "versioning": "regex:^release-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/linuxserver/qbittorrent"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-libtorrentv1$"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["lscr.io/linuxserver/plex"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?:\\.(?<build>\\d+))?(?:-[A-Za-z0-9]+)?(?:-ls(?<revision>\\d+))?$"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["docker.io/haveagitgat/tdarr", "docker.io/haveagitgat/tdarr_node"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["cloudflare/cloudflared", "ghcr.io/openclaw/openclaw"],
      "versioning": "regex:^(?<major>\\d{4})\\.(?<minor>\\d{1,2})\\.(?<patch>\\d+)$"
    }
  ]
}
